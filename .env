# ─────────────────────────────────────────────────────────────────────────────
#  GCS-WAF v2.0  —  Environment Configuration
#  Copy to .env and fill in your values before running docker-compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports ─────────────────────────────────────────────────────────────────────
WAF_HTTP_PORT=80
WAF_HTTPS_PORT=443
DASHBOARD_PORT=8080

# ── Backend (the app GCS-WAF protects) ────────────────────────────────────────
BACKEND_HOST=your-app-container-or-ip
BACKEND_PORT=8888

# ── Security ──────────────────────────────────────────────────────────────────
# CHANGE THIS — used for bot challenge token signing
WAF_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_32_CHARS

# ── GeoIP (MaxMind GeoLite2) ──────────────────────────────────────────────────
# Register free at: https://www.maxmind.com/en/geolite2/signup
# Then get your license key from: https://www.maxmind.com/en/accounts/current/license-key
MAXMIND_LICENSE_KEY=YOUR_MAXMIND_LICENSE_KEY_HERE

# ── Country Blocking (comma-separated ISO codes, leave empty to disable) ──────
# Example: GCS_BLOCKED_COUNTRIES=KP,IR,RU
GCS_BLOCKED_COUNTRIES=

# ── HTTPS / Let's Encrypt ─────────────────────────────────────────────────────
WAF_DOMAIN=your-domain.com
CERTBOT_EMAIL=admin@your-domain.com

# ── Alerting (optional) ───────────────────────────────────────────────────────
# Slack webhook for attack alerts
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Email for digest reports
ALERT_EMAIL=security@your-domain.com
